# =============================================================================
# AI Subtitle Generator — Environment variable reference
# Copy this file to .env.local for local dev, or .env.production on the VPS.
# Never commit real keys. Phases will add their own variables here over time.
# =============================================================================

# --- App ---
# Public URL of the app. http://localhost:3000 for dev, https://aisubtitle.online in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Phase 1: Auth) ---
# Project URL from Supabase Dashboard → Project Settings → API Keys.
NEXT_PUBLIC_SUPABASE_URL=

# Anon / Publishable key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role / Secret key. SERVER ONLY. Bypasses Row Level Security.
# Never expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Phase 2: Prisma + Supabase Postgres) ---
# Supabase Session pooler (port 5432) is the recommended choice — IPv4-friendly
# and supports Prisma's prepared statements. Format:
# postgresql://postgres.<project-ref>:<password>@aws-X-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# --- Stripe (Phase 3) ---
# Restricted key (rk_test_ in test mode, rk_live_ in production).
# Server-only — never expose to the browser.
STRIPE_SECRET_KEY=

# Publishable key (pk_test_ in test mode, pk_live_ in production).
# Safe to expose to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret. In dev, this comes from `stripe listen` output.
# In production, from the Webhooks endpoint you create in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=

# --- Subtitle backend (Phase 4) ---
# URL of the FastAPI transcription service at /root/subtitle_api.
SUBTITLE_API_URL=http://127.0.0.1:8000

# --- PostHog (Phase 5) ---
# Project API key from PostHog → Settings → Project (starts with phc_).
NEXT_PUBLIC_POSTHOG_KEY=

# EU Cloud: https://eu.posthog.com  |  US Cloud: https://us.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
